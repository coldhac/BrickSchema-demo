@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix brick: <https://brickschema.org/schema/Brick#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix demo:  <urn:demo:shapes#> .

# ===========================================================================
# 冷水机房专属 SHACL 校验规则
# 替代现有方案中手写的 Python 校验逻辑
# ===========================================================================

# ---------------------------------------------------------------------------
# 规则 1：每台冷水主机必须归属于某个冷水机房（替代"无孤立节点"检查）
# ---------------------------------------------------------------------------
demo:ChillerPartOfShape a sh:NodeShape ;
    sh:targetClass brick:Chiller ;
    sh:property [
        sh:path brick:isPartOf ;
        sh:minCount 1 ;
        sh:message "冷水主机必须通过 isPartOf 归属于某个冷水机房" ;
    ] .

# ---------------------------------------------------------------------------
# 规则 2：每台冷冻泵必须归属于某个冷水机房
# ---------------------------------------------------------------------------
demo:PumpPartOfShape a sh:NodeShape ;
    sh:targetClass brick:Chilled_Water_Pump ;
    sh:property [
        sh:path brick:isPartOf ;
        sh:minCount 1 ;
        sh:message "冷冻泵必须通过 isPartOf 归属于某个冷水机房" ;
    ] .

# ---------------------------------------------------------------------------
# 规则 3：每台冷水主机必须至少有一个电力功率传感器（替代"必要点位"检查）
# ---------------------------------------------------------------------------
demo:ChillerHasPowerSensorShape a sh:NodeShape ;
    sh:targetClass brick:Chiller ;
    sh:property [
        sh:path [ sh:inversePath brick:isPointOf ] ;
        sh:qualifiedValueShape [ sh:class brick:Electric_Power_Sensor ] ;
        sh:qualifiedMinCount 1 ;
        sh:message "冷水主机缺少电力功率传感器（Electric_Power_Sensor）" ;
    ] .

# ---------------------------------------------------------------------------
# 规则 4：每台冷水主机必须至少有一个供水温度传感器
# ---------------------------------------------------------------------------
demo:ChillerHasSupplyTempShape a sh:NodeShape ;
    sh:targetClass brick:Chiller ;
    sh:property [
        sh:path [ sh:inversePath brick:isPointOf ] ;
        sh:qualifiedValueShape [ sh:class brick:Chilled_Water_Supply_Temperature_Sensor ] ;
        sh:qualifiedMinCount 1 ;
        sh:message "冷水主机缺少冷冻供水温度传感器" ;
    ] .

# ---------------------------------------------------------------------------
# 规则 5：每台冷冻泵必须至少有一个频率传感器
# ---------------------------------------------------------------------------
demo:PumpHasFreqSensorShape a sh:NodeShape ;
    sh:targetClass brick:Chilled_Water_Pump ;
    sh:property [
        sh:path [ sh:inversePath brick:isPointOf ] ;
        sh:qualifiedValueShape [ sh:class brick:Frequency_Sensor ] ;
        sh:qualifiedMinCount 1 ;
        sh:message "冷冻泵缺少运行频率传感器（Frequency_Sensor）" ;
    ] .

# ---------------------------------------------------------------------------
# 规则 6：冷水机房必须至少有一个总功率传感器
# ---------------------------------------------------------------------------
demo:ChillerPlantHasPowerShape a sh:NodeShape ;
    sh:targetClass brick:Chiller_Plant ;
    sh:property [
        sh:path [ sh:inversePath brick:isPointOf ] ;
        sh:qualifiedValueShape [ sh:class brick:Electric_Power_Sensor ] ;
        sh:qualifiedMinCount 1 ;
        sh:message "冷水机房缺少总功率传感器" ;
    ] .
